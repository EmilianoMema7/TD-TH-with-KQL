// Title: Adware Wallpaper Chrome Extension Campaign
// Description: Detects suspicious Chrome/Chromium process executions and network connections related to the 2026-06 Wallpaper Adware Chrome Extension campaign observed by Unit42.
// Source: https://github.com/PaloAltoNetworks/Unit42-timely-threat-intel/blob/main/2026-06-01-Adware-Wallpaper-Chrome-Extension-Campaign.txt
// MITRE ATT&CK: 
//T1547 (Boot or Logon Autostart Execution), 
//T1071.001 (Application Layer Protocol: Web Protocols), 
//T1059.003 (Command and Scripting Interpreter: Windows Command Shell)
// Expected Result: Correlated Chrome/Chromium processes running known malicious extension IDs and associated network connections to suspicious domains.
// False Positives: May include legitimate Chrome extensions sharing similar patterns or non-malicious connections to related domains.
// Known IOCs:
//   Domains: gameograf.com, ovkas.com, chromewallpaper.com, owhit.com
//   Chrome Extension IDs: List of numerous known malicious extension IDs from Unit42 report

let Lookback = 30d;
// Suspicious Chrome extension IDs extracted from known adware campaign telemetry
let SuspiciousExtensions = dynamic([
