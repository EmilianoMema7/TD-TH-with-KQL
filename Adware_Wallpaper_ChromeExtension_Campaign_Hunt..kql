  "cdfjefamdaghbhmlddgnfneonpjbbehp",
  "phcfjgnhnpfjhpghiacilpocpcdcgljm",
  "fipehnelbojemafmdmhdkphjnafdnfle",
  "fnfaggodhehejkigojefdehaffoneokd",
  "jbaghkaihalnmkknemcgjikkimiecgpn",
  "famoeaahdjkggighmjpagpjmcmbinkia",
  "ooepolkedgpkhojiihdjoajnjohciajl",
  "gpkgjopaiakcnokecmocecnbpghkkjhg",
  "pkmjadcejhbaahnlaooacmfkfflpkcic",
  "fipehnelbojemafmdmhdkphjnafdnfle"
]);
// Suspicious domains related to the campaign
let SuspiciousDomains = dynamic([
  "gameograf.com",
  "ovkas.com",
  "chromewallpaper.com",
  "owhit.com"
]);
// Detect suspicious Chrome/Chromium processes with extension IDs in command line
let SuspiciousChromeProcesses = DeviceProcessEvents
| where Timestamp >= ago(Lookback)
| where FileName has "chrome" or FileName has "chromium"
| where ProcessCommandLine has_any (SuspiciousExtensions)
| project DeviceId, AccountName, FileName, ProcessCommandLine, SHA256, Timestamp;
// Detect outbound network connections from Chrome/Chromium processes to suspicious domains
let SuspiciousChromeConnections = DeviceNetworkEvents
| where Timestamp >= ago(Lookback)
| where InitiatingProcessFileName has "chrome" or InitiatingProcessFileName has "chromium"
| where RemoteUrl has_any (SuspiciousDomains)
| project DeviceId, AccountName=InitiatingProcessAccountName, FileName=InitiatingProcessFileName, ProcessCommandLine=InitiatingProcessCommandLine,
          RemoteUrl, RemoteIP, SHA256=InitiatingProcessSHA256, Timestamp;
// Correlate suspicious Chrome execution events with related network connections for higher confidence alert
SuspiciousChromeProcesses
| join kind=inner (
    SuspiciousChromeConnections
) on DeviceId, ProcessCommandLine
| project Timestamp=coalesce(Timestamp, Timestamp1),
          DeviceId,
          AccountName,
          FileName,
          ProcessCommandLine,
          RemoteUrl,
          RemoteIP,
          SHA256
| sort by Timestamp desc
